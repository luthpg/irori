{
  "name": "backend",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "db:create": "wrangler d1 create irori-db",
    "db:migrate": "wrangler d1 migrations apply irori-db --local",
    "db:push": "wrangler d1 migrations push irori-db --local",
    "db:typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.29"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260712.1",
    "drizzle-kit": "^0.31.10",
    "wrangler": "^4.110.0"
  }
}