{
  "name": "backend",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "deploy": "wrangler deploy --minify",
