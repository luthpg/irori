    "hono": "^4.12.30"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260717.1",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "~7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}